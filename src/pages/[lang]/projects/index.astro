---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { languages } from '../../../i18n/config';
import { ui, uiLabel } from '../../../i18n/ui';
import { getFeaturedProjects, getProjectsByCategory } from '../../../data/projects';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const featured = getFeaturedProjects();
const archive = getProjectsByCategory('archive');
---

<SiteLayout lang={lang!} title={uiLabel(ui.nav.projects, lang!)} currentPath="projects">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h1 class="section-title mb-4">{uiLabel(ui.nav.projects, lang!)}</h1>
    <p class="mb-12 max-w-2xl text-zinc-400">
      {
        lang === 'ar'
          ? 'مجموعة من المشاريع المهنية — مع التركيز على مساهماتي في Backend.'
          : 'A collection of professional projects — focused on my backend contributions.'
      }
    </p>

    <h2 class="mb-6 text-lg font-semibold text-emerald-400">{uiLabel(ui.sections.featured, lang!)}</h2>
    <div class="mb-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((project) => <ProjectCard lang={lang!} project={project} />)}
    </div>

    <h2 class="mb-6 text-lg font-semibold text-zinc-300">{uiLabel(ui.sections.archive, lang!)}</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {archive.map((project) => <ProjectCard lang={lang!} project={project} />)}
    </div>
  </section>
</SiteLayout>
