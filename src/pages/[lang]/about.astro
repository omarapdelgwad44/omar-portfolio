---
import SiteLayout from '../../layouts/SiteLayout.astro';
import ExperienceTimeline from '../../components/ExperienceTimeline.astro';
import SkillsGrid from '../../components/SkillsGrid.astro';
import { languages } from '../../i18n/config';
import { ui, uiLabel } from '../../i18n/ui';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<SiteLayout lang={lang!} title={uiLabel(ui.about.title, lang!)} currentPath="about">
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 md:py-20">
    <h1 class="section-title mb-8">{uiLabel(ui.about.title, lang!)}</h1>
    <div class="prose-portfolio space-y-6">
      <p>{uiLabel(ui.about.p1, lang!)}</p>
      <p>{uiLabel(ui.about.p2, lang!)}</p>
      <p class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 px-4 py-3 text-emerald-300/90">
        {uiLabel(ui.about.currently, lang!)}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h2 class="section-title mb-10">{uiLabel(ui.sections.experience, lang!)}</h2>
    <ExperienceTimeline lang={lang!} />
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
    <SkillsGrid lang={lang!} />
  </section>
</SiteLayout>
