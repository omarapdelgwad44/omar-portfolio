---
import type { Lang } from '../types';
import { localizedPath } from '../i18n/config';
import { ui, uiLabel } from '../i18n/ui';
import ProfilePhoto from './ProfilePhoto.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const cvPath = `${import.meta.env.BASE_URL}cv/Omar_Ahmed_Sayed.pdf`.replace(/\/{2,}/g, '/');

const highlights =
  lang === 'ar'
    ? ['Laravel & Livewire', 'REST APIs', 'E-Commerce Backends']
    : ['Laravel & Livewire', 'REST APIs', 'E-Commerce Backends'];
---

<section class="hero-section relative overflow-hidden py-16 md:py-24 lg:py-28">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-500/12 via-transparent to-transparent" />
  <div class="pointer-events-none absolute inset-0 hero-grid opacity-40" />

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <!-- Photo — first on mobile -->
      <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
        <div class="relative">
          <ProfilePhoto size="hero" />
          <div class="absolute -bottom-3 start-1/2 flex -translate-x-1/2 gap-2 rounded-full border border-zinc-700/80 bg-zinc-900/90 px-4 py-2 backdrop-blur-md">
            <span class="h-2 w-2 rounded-full bg-emerald-400 animate-pulse" />
            <span class="text-xs font-medium text-zinc-300">
              {lang === 'ar' ? 'متاح للعمل' : 'Available for work'}
            </span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="order-2 lg:order-1">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-emerald-400">
          {uiLabel(ui.hero.greeting, lang)}
        </p>
        <h1 class="mb-4 text-4xl font-bold tracking-tight text-white md:text-5xl lg:text-6xl">
          {uiLabel(ui.hero.name, lang)}
        </h1>
        <p class="mb-6 max-w-xl text-lg leading-relaxed text-zinc-400 md:text-xl">
          {uiLabel(ui.hero.tagline, lang)}
        </p>

        <div class="mb-8 flex flex-wrap gap-2">
          {
            highlights.map((item) => (
              <span class="rounded-lg border border-zinc-800 bg-zinc-900/60 px-3 py-1.5 text-xs font-medium text-zinc-300">
                {item}
              </span>
            ))
          }
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            href={localizedPath(lang, 'projects')}
            class="rounded-xl bg-emerald-500 px-6 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-emerald-400 hover:shadow-lg hover:shadow-emerald-500/20"
          >
            {uiLabel(ui.hero.ctaProjects, lang)}
          </a>
          <a
            href={localizedPath(lang, 'contact')}
            class="rounded-xl border border-zinc-700 px-6 py-3 text-sm font-semibold text-white transition hover:border-emerald-500/50 hover:bg-zinc-900"
          >
            {uiLabel(ui.hero.ctaContact, lang)}
          </a>
          <a
            href={cvPath}
            download
            class="rounded-xl border border-zinc-700 px-6 py-3 text-sm font-semibold text-zinc-300 transition hover:border-zinc-600 hover:text-white"
          >
            {uiLabel(ui.hero.ctaCv, lang)}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
