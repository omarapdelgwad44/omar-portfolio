---
import type { Lang } from '../types';
import { experiences } from '../data/experience';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="relative space-y-8 before:absolute before:inset-y-0 before:start-4 before:w-px before:bg-zinc-800 md:before:start-6">
  {
    experiences.map((exp) => (
      <div class="relative ps-12 md:ps-16">
        <div class="absolute start-2.5 top-1.5 h-3 w-3 rounded-full border-2 border-emerald-500 bg-zinc-950 md:start-4.5" />
        <div class="card p-6">
          <div class="mb-1 flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h3 class="text-lg font-bold text-white">{exp.company[lang]}</h3>
            <span class="text-sm text-emerald-400">{exp.period}</span>
          </div>
          <p class="mb-1 text-sm font-medium text-zinc-300">{exp.role[lang]}</p>
          <p class="mb-4 text-xs text-zinc-500">{exp.location[lang]}</p>
          <ul class="space-y-2">
            {exp.highlights.map((item) => (
              <li class="flex gap-2 text-sm text-zinc-400">
                <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-emerald-500" />
                {item[lang]}
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))
  }
</div>
