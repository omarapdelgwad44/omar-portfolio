---
import type { Lang } from '../types';
import type { Project } from '../types';
import { localizedPath } from '../i18n/config';
import { ui, uiLabel } from '../i18n/ui';
import { getProjectLink, linkHostname } from '../data/project-links';
import ProjectLogo from './ProjectLogo.astro';

interface Props {
  lang: Lang;
  project: Project;
}

const { lang, project } = Astro.props;
const title = project.title[lang];
const tagline = project.tagline[lang];
const company = project.company?.[lang];
const projectLink = getProjectLink(project.slug);
---

<article class="card group flex h-full flex-col overflow-hidden">
  <div class="relative border-b border-zinc-800/80 bg-gradient-to-br from-zinc-900/90 via-zinc-900/50 to-zinc-950/90 px-6 py-7">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_80%_0%,rgba(16,185,129,0.07),transparent_50%)]"
    >
    </div>
    <div class="relative flex items-start justify-between gap-4">
      <ProjectLogo slug={project.slug} title={title} size="card" />
      <div class="flex flex-wrap justify-end gap-2">
        {
          project.status === 'in-progress' && (
            <span class="badge-warning">{uiLabel(ui.project.status['in-progress'], lang)}</span>
          )
        }
        {
          project.status === 'in-development' && (
            <span class="badge-warning">{uiLabel(ui.project.status['in-development'], lang)}</span>
          )
        }
        {company && <span class="badge-accent">{company}</span>}
      </div>
    </div>
  </div>

  <div class="flex flex-1 flex-col p-6">
    <h3 class="mb-2 text-xl font-bold text-white transition group-hover:text-emerald-400">
      {title}
    </h3>
    <p class="mb-4 flex-1 text-sm leading-relaxed text-zinc-400">{tagline}</p>

    <div class="mb-4 flex flex-wrap gap-1.5">
      {
        project.stack.slice(0, 4).map((tech) => (
          <span class="rounded-md bg-zinc-800/80 px-2 py-0.5 text-xs text-zinc-400">{tech}</span>
        ))
      }
      {
        project.stack.length > 4 && (
          <span class="rounded-md bg-zinc-800/80 px-2 py-0.5 text-xs text-zinc-500">
            +{project.stack.length - 4}
          </span>
        )
      }
    </div>

    <div class="mt-auto flex flex-wrap items-center gap-3">
      <a
        href={localizedPath(lang, `projects/${project.slug}`)}
        class="inline-flex items-center gap-1 text-sm font-semibold text-emerald-400 transition hover:text-emerald-300"
      >
        {uiLabel(ui.project.viewCase, lang)}
        <span aria-hidden="true" class={lang === 'ar' ? 'rotate-180' : ''}>→</span>
      </a>
      {
        projectLink?.liveUrl && (
          <a
            href={projectLink.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-500/10 px-3 py-1.5 text-sm font-semibold text-emerald-400 ring-1 ring-emerald-500/30 transition hover:bg-emerald-500/20"
          >
            ↗ {uiLabel(ui.project.liveSite, lang)}
          </a>
        )
      }
      {
        projectLink?.videoUrl && (
          <a
            href={projectLink.videoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800 px-3 py-1.5 text-sm font-semibold text-zinc-300 ring-1 ring-zinc-700 transition hover:bg-zinc-700"
          >
            ▶ {uiLabel(ui.project.watchDemo, lang)}
          </a>
        )
      }
    </div>
    {
      projectLink?.liveUrl && (
        <p class="mt-2 text-xs text-zinc-500">
          {projectLink.host ? projectLink.host[lang] : linkHostname(projectLink.liveUrl)}
        </p>
      )
    }
  </div>
</article>
